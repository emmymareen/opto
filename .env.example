# Opto configuration — copy to .env and edit. All vars are optional.

# --- Proxy ---
OPTO_HOST=127.0.0.1
OPTO_PORT=8799
OPTO_UPSTREAM_BASE_URL=https://api.githubcopilot.com

# --- Compression ---
OPTO_ENABLED=true
OPTO_MIN_TOKENS_TO_COMPRESS=400
OPTO_TARGET_RATIO=0.45

# --- Relevance ---
OPTO_RELEVANCE_DROP_THRESHOLD=0.12

# --- Quality guarantee ---
OPTO_QUALITY_GATE_ENABLED=true
OPTO_QUALITY_RISK_THRESHOLD=0.7
OPTO_HOLDOUT_FRACTION=0.0

# --- Enterprise Copilot auth bridge ---
# Let Opto perform the GitHub->Copilot token exchange itself (no API key needed).
OPTO_MANAGE_COPILOT_AUTH=false
OPTO_GITHUB_HOST=github.com
# Only if auto-discovery can't find your token:
# OPTO_COPILOT_GITHUB_TOKEN=ghu_xxx

# --- Privacy / enterprise ---
OPTO_REDACT_CONTENT_IN_LOGS=true
